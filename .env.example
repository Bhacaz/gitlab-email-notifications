# Copy this file to .env and fill in the values for local development.
# In production, set these as environment variables (e.g. via docker-compose.yml).
# .env is gitignored and must never be committed.

# ─── Rails ────────────────────────────────────────────────────────────────────
# Generate with: bin/rails secret
SECRET_KEY_BASE=

# ─── GitLab OAuth Application ─────────────────────────────────────────────────
# Create at https://gitlab.com/-/profile/applications
# Name: GitLab Email Notifications
# Redirect URI: https://your-domain.example.com/oauth/gitlab/callback
# Scopes: read_user
GITLAB_APP_ID=
GITLAB_APP_SECRET=
GITLAB_CALLBACK_URL=https://your-domain.example.com/oauth/gitlab/callback

# ─── Email / Mailgun ──────────────────────────────────────────────────────────
# The custom domain you configured in Mailgun (e.g. gitlab.example.com).
# Incoming notifications from GitLab must be sent to <prefix>@EMAIL_DOMAIN.
EMAIL_DOMAIN=gitlab.example.com

# The HTTP webhook signing key from Mailgun API Security settings.
MAILGUN_SIGNING_KEY=key-

# ─── Admin panel ──────────────────────────────────────────────────────────────
# Protects /admin/* (SolidErrors, SolidAPM, SolidQueueDashboard) with HTTP Basic Auth.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ─── Optional ─────────────────────────────────────────────────────────────────
# RAILS_LOG_LEVEL=info
