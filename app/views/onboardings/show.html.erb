<%# frozen_string_literal: true %>
<%= turbo_stream_from "onboarding_#{current_user.id}" %>

<div class="hero min-h-[80vh]">
  <div class="hero-content w-full max-w-2xl">
    <div class="card bg-base-200 shadow-xl w-full">
      <div class="card-body gap-6">

        <%# Header %>
        <div class="flex items-center gap-3">
          <i class="bi bi-gitlab text-4xl text-primary"></i>
          <div>
            <h1 class="card-title text-2xl">Set up your notifications</h1>
            <p class="text-base-content/60 text-sm">Follow the steps below to start receiving GitLab notifications.</p>
          </div>
        </div>

        <div class="divider my-0"></div>

        <%# Step 1 %>
        <div class="flex items-start gap-3">
          <div class="badge badge-primary badge-lg font-bold shrink-0 mt-0.5">1</div>
          <div class="flex-1">
            <p class="font-semibold text-base-content">Add this email to your GitLab profile</p>
            <p class="text-sm text-base-content/60 mt-1">
              Go to your
              <a href="https://gitlab.com/-/profile/emails"
                 target="_blank"
                 rel="noopener noreferrer"
                 class="link link-primary">
                GitLab profile emails <i class="bi bi-box-arrow-up-right text-xs"></i>
              </a>
              and add the address below as a new email.
            </p>

            <%# Email address copy box %>
            <% email_address = current_user.notification_email %>
            <div class="mt-3"
                 data-controller="clipboard"
                 data-clipboard-text-value="<%= email_address %>">
              <div class="join w-full">
                <div class="join-item input input-bordered bg-base-100 flex items-center flex-1 font-mono text-sm select-all">
                  <%= email_address %>
                </div>
                <button class="btn btn-primary join-item"
                        data-action="click->clipboard#copy">
                  <i class="bi bi-clipboard"></i>
                  <span data-clipboard-target="label">Copy</span>
                </button>
              </div>
            </div>
          </div>
        </div>

        <%# Step 2 — status area, replaced live via Turbo Stream %>
        <div class="flex items-start gap-3">
          <div class="badge badge-ghost badge-lg font-bold shrink-0 mt-0.5">2</div>
          <div class="flex-1">
            <p class="font-semibold text-base-content">Confirm your email</p>
            <p class="text-sm text-base-content/60 mt-1">
              GitLab will send a confirmation email to the address above. This page will update automatically when it arrives.
            </p>
            <%= render "onboardings/status", onboarding: @onboarding %>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
