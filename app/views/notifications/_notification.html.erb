<li class="list-row" id="notification_<%= notification.id %>">
  <%# Icon col — reason %>
  <div class="flex items-center">
    <% if notification.reason_pipeline_failed? %>
      <div class="tooltip" data-tip="Pipeline failed">
        <i class="bi bi-x-circle-fill text-error text-xl"></i>
      </div>
    <% else %>
      <div class="tooltip" data-tip="Notification">
        <i class="bi bi-bell-fill text-base-content/40 text-xl"></i>
      </div>
    <% end %>
  </div>

  <%# Main content col %>
  <div class="list-col-grow min-w-0">
    <%# Subject — prominent, external link if available %>
    <% if notification.link.present? %>
      <a href="<%= notification.link %>" target="_blank" rel="noopener noreferrer"
         class="link link-hover font-semibold leading-snug line-clamp-1 text-base-content">
        <%= notification.title %>
        <i class="bi bi-box-arrow-up-right text-xs ml-1 opacity-50"></i>
      </a>
    <% else %>
      <p class="font-semibold leading-snug line-clamp-1 text-base-content"><%= notification.title %></p>
    <% end %>

    <%# Secondary line — repo / ref / MR / timestamp %>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-0.5 text-xs text-base-content/40">
      <% if notification.repo.present? %>
        <span class="flex items-center gap-1">
          <i class="bi bi-folder2"></i><%= notification.repo %>
        </span>
      <% end %>
      <% if notification.summary.present? %>
        <span class="flex items-center gap-1 line-clamp-1">
          <i class="bi bi-signpost-split"></i><%= notification.summary %>
        </span>
      <% end %>
      <span class="pt-3"><%= time_ago_in_words(notification.created_at) %> ago</span>
    </div>
  </div>

  <%# View email button %>
  <%= link_to notification_path(notification), class: 'btn btn-ghost btn-sm btn-square', title: 'View email' do %>
    <i class="bi bi-envelope text-base-content/60"></i>
  <% end %>

  <%# Hide (checkmark) button %>
  <%= button_to hide_notification_path(notification), method: :patch,
        data: { turbo_stream: true },
        class: 'btn btn-ghost btn-sm btn-square text-success',
        title: 'Mark as done',
        form: { 'data-turbo-stream': true } do %>
    <i class="bi bi-check-lg text-lg"></i>
  <% end %>
</li>
