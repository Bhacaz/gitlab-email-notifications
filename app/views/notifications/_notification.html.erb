<li class="list-row" id="notification_<%= notification.id %>">
  <%# Icon col — reason %>
  <% reason = Notification::REASONS.find { |r| r.name.to_s == notification.reason } %>
  <div class="flex items-center">
    <div class="tooltip" data-tip="<%= reason&.display_name || 'Notification' %>">
      <i class="<%= reason&.icon_class || 'fa-solid fa-bell' %> text-base-content/40 text-xl"></i>
    </div>
  </div>

  <%# Main content col %>
  <div class="list-col-grow min-w-0">
    <%# Title — prominent, external link if available %>
    <div class="pb-1">
      <% if notification.link.present? %>
        <a href="<%= notification.link %>" target="_blank" rel="noopener noreferrer"
           class="link link-hover font-semibold leading-snug line-clamp-1 text-base-content">
          <%= notification.title %>
        </a>
      <% else %>
        <p class="font-semibold leading-snug line-clamp-1 text-base-content"><%= notification.title %></p>
      <% end %>
    </div>

    <%# Secondary line — repo / summary / timestamp %>
    <div class="flex flex-col gap-y-1 mt-0.5 text-xs text-base-content/40">
      <% if notification.summary.present? %>
        <span class="truncate text-base-content/50 mb-3"><%= notification.summary %></span>
      <% end %>
      <div class="flex items-center gap-1 min-w-0 overflow-hidden">
        <% if notification.repo.present? %>
          <span class="flex items-center gap-1 shrink-0">
            <i class="bi bi-folder2"></i><%= notification.repo %>
          </span>
        <% end %>
        <span>・ </span>
        <span><%= time_ago_in_words(notification.created_at) %> ago</span>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%# Unsubscribe button — only shown when a link was parsed from the email %>
    <% if notification.unsubscribe_link.present? %>
      <%= link_to notification.unsubscribe_link,
                  target: '_blank', rel: 'noopener noreferrer',
                  class: 'btn btn-ghost btn-sm btn-square text-base-content/40',
                  title: 'Unsubscribe' do %>
        <i class="bi bi-bell-slash"></i>
      <% end %>
    <% end %>

    <%# View email button %>
    <%= link_to notification_path(notification), class: 'btn btn-ghost btn-sm btn-square', title: 'View email' do %>
      <i class="bi bi-envelope text-base-content/60"></i>
    <% end %>

    <%# Hide (checkmark) button %>
    <%= button_to hide_notification_path(notification), method: :patch,
                  data: { turbo_stream: true },
                  class: 'btn btn-ghost btn-sm btn-square text-success',
                  title: 'Mark as done',
                  form: { 'data-turbo-stream': true } do %>
      <i class="bi bi-check-lg text-lg"></i>
    <% end %>
  </div>
</li>
