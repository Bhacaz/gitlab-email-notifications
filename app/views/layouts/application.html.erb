<!DOCTYPE html>
<html data-theme="dim" lang="en">
  <head>
    <title><%= content_for(:title) || Rails.app_class.name.split('::').first %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if user_signed_in? && Rails.application.config.x.vapid&.public_key.present? %>
      <meta name="vapid-public-key" content="<%= Rails.application.config.x.vapid&.public_key %>">
    <% end %>

    <%= yield :head %>

    <%= tag.link rel: 'manifest', href: pwa_manifest_path(format: :json) %>

    <link rel="icon" id="favicon" href="/favicon-bell.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag 'tailwind', 'data-turbo-track': 'reload' %>
    <%= stylesheet_link_tag 'application', 'data-turbo-track': 'reload' %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <%= turbo_stream_from "notifications_new_#{current_user.id}" %>
    <% end %>

    <nav class="navbar bg-base-100 shadow-sm fixed top-0 z-50 w-full px-4">
      <div class="flex-1">
        <a href="<%= root_path %>" class="btn btn-ghost text-xl">
          <i class="bi bi-gitlab"></i>
          <%= Rails.app_class.name.split('::').first %>
        </a>
      </div>
      <div class="flex-none">
        <% if user_signed_in? %>
          <div id="new-notifications-banner"></div>
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
              <div class="w-10 rounded-full">
                <% if current_user.avatar_url.present? %>
                  <img src="<%= current_user.avatar_url %>" alt="<%= current_user.name %>" referrerpolicy="no-referrer">
                <% else %>
                  <div class="avatar-placeholder">
                    <div class="bg-neutral text-neutral-content w-10 rounded-full">
                      <span class="text-lg font-bold"><%= current_user.name&.first&.upcase %></span>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
            <div tabindex="0" class="dropdown-content bg-base-100 rounded-box z-[1] mt-3 w-64 shadow-lg overflow-hidden">
              <div class="px-4 pt-3 pb-2 min-w-0">
                <p class="font-semibold text-sm truncate"><%= current_user.name %></p>
                <p class="text-xs text-base-content/50 truncate">@<%= current_user.username %></p>
                <p class="text-xs text-base-content/50 truncate"><%= current_user.notification_email %></p>
              </div>
              <div class="divider my-0"></div>
              <ul class="menu menu-sm p-2">
                <% if Rails.application.config.x.vapid&.public_key.present? %>
                  <li>
                    <div data-controller="push-subscription"
                         data-push-subscription-vapid-public-key-value="<%= Rails.application.config.x.vapid&.public_key %>"
                         data-action="click->push-subscription#toggle">
                      <i data-push-subscription-target="icon" class="bi bi-bell-slash"></i>
                      <span data-push-subscription-target="label">Enable push notifications</span>
                    </div>
                  </li>
                <% end %>
                <li>
                  <%= button_to sign_out_path, method: :delete, data: { turbo: false }, class: 'w-full' do %>
                    <i class="bi bi-box-arrow-right"></i> Sign out
                  <% end %>
                </li>
              </ul>
            </div>
          </div>
        <% else %>
          <%= button_to '/auth/gitlab', data: { turbo: false }, class: 'btn btn-primary btn-sm' do %>
            <i class="bi bi-gitlab"></i> Sign in with GitLab
          <% end %>
        <% end %>
      </div>
    </nav>

    <div class="toast toast-end toast-bottom z-50">
      <% if notice.present? %>
        <div role="alert" class="alert alert-success shadow-lg transition-all duration-300"
             data-controller="flash">
          <i class="bi bi-check-circle"></i>
          <span><%= notice %></span>
          <button type="button" class="btn btn-ghost btn-xs" data-action="flash#dismiss">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
      <% end %>

      <% if alert.present? %>
        <div role="alert" class="alert alert-error shadow-lg transition-all duration-300"
             data-controller="flash">
          <i class="bi bi-exclamation-triangle"></i>
          <span><%= alert %></span>
          <button type="button" class="btn btn-ghost btn-xs" data-action="flash#dismiss">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
      <% end %>
    </div>

    <main class="container mx-auto mt-20 px-5 flex">
      <%= yield %>
    </main>
  </body>
</html>
