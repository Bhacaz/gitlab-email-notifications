<%= turbo_stream_from "notifications_new_#{current_user.id}" %>

<div class="w-full max-w-3xl mx-auto">
  <%# New notifications banner — replaced via Turbo Stream on new arrivals %>
  <div id="new-notifications-banner"></div>

  <% if @notifications.any? %>
    <ul class="list bg-base-200 rounded-box shadow-sm">
      <li class="p-4 pb-2 text-xs text-base-content/50 tracking-widest uppercase font-semibold">
        Notifications
      </li>
      <%= render @notifications %>
    </ul>
  <% else %>
    <div class="flex flex-col items-center justify-center py-24 text-base-content/30">
      <i class="bi bi-inbox text-5xl mb-4"></i>
      <p class="text-lg font-semibold">All caught up</p>
      <p class="text-sm mt-1">No visible notifications</p>
    </div>
  <% end %>
</div>
