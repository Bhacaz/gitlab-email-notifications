<%= turbo_stream_from "notifications_new_#{current_user.id}" %>

<div class="w-full flex gap-8 items-start">

  <%# ── Sidebar filters ── %>
  <aside class="shrink-0 sticky top-20">
    <%= render 'home/sidebar_filters',
          all_count: @all_count,
          reasons: @reasons,
          repos: @repos,
          active_reason: @active_reason,
          active_repo: @active_repo %>
  </aside>

  <%# ── Notification list ── %>
  <div class="flex-1 min-w-0">
    <%# New notifications banner — replaced via Turbo Stream on new arrivals %>
    <div id="new-notifications-banner"></div>

    <% if @notifications.any? %>
      <ul class="list bg-base-200 rounded-box shadow-sm">
        <li class="p-4 pb-2 text-xs text-base-content/50 tracking-widest uppercase font-semibold flex items-center justify-between">
          <span>Notifications</span>
        </li>
        <%= render @notifications %>
      </ul>
    <% else %>
      <div class="flex flex-col items-center justify-center py-24 text-base-content/30">
        <i class="bi bi-inbox text-5xl mb-4"></i>
        <% if @active_reason.present? || @active_repo.present? %>
          <p class="text-lg font-semibold">No matches</p>
          <p class="text-sm mt-1">
            <%= link_to 'Clear filter', root_path, class: 'link link-hover text-base-content/40' %>
          </p>
        <% else %>
          <p class="text-lg font-semibold">All caught up</p>
          <p class="text-sm mt-1">No visible notifications</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
