<%= turbo_stream_from "notifications_new_#{current_user.id}" %>

<div class="w-full flex gap-8 items-start">

  <%# ── Sidebar filters ── %>
  <aside class="shrink-0 sticky top-20">
    <%= render 'home/sidebar_filters',
          all_count: @all_count,
          reasons: @reasons,
          repos: @repos,
          active_reason: @active_reason,
          active_repo: @active_repo %>
  </aside>

  <%# ── Notification list ── %>
  <div class="flex-1 min-w-0">
    <%# New notifications banner — replaced via Turbo Stream on new arrivals %>
    <div id="new-notifications-banner"></div>

    <%= render 'home/notification_list',
          notifications: @notifications,
          active_reason: @active_reason,
          active_repo: @active_repo %>
  </div>
</div>
